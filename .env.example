# RevivalSide local server
CS_PORT=22000
CS_HTTP_MIRROR_PORT=8088
CS_GAME_SERVER_IP=127.0.0.1
CS_GAME_SERVER_PORT=22000

# Local CounterSide installation. Change this if Steam is installed elsewhere.
CS_COUNTERSIDE_MANAGED_DIR=C:\Program Files (x86)\Steam\steamapps\common\CounterSide\Data\Managed

# Generated locally. See docs/setup.md.
CS_GAMEPLAY_TABLES_DIR=.\gameplay-tables
CS_CAPTURED_FLOW_DIR=.\server-data\captured-flows
CS_CAPTURED_TCP_DIR=.\server-data\captured-tcp
CS_CAPTURED_GAME_FLOW_DIR=.\server-data\captured-game-flow

# Combat host. Leave the project path enabled while developing; use the prebuilt DLL for quick smoke tests.
CS_CSHARP_COMBAT_HOST=1
CS_CSHARP_COMBAT_HOST_PROJECT=.\combat-host\CombatHost.csproj
# CS_CSHARP_COMBAT_HOST_DLL=.\prebuilt\combat-host\CombatHost.dll

# Useful debugging toggles.
CS_VERBOSE_CAPTURE=0
CS_DEBUG_HEX=0
CS_LOG_CONFIG_EACH_CONNECTION=0
CS_DYNAMIC_BATTLE_SYNC_INTERVAL_MS=33
