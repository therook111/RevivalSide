# RevivalSide local server
CS_PORT=22000
CS_HTTP_MIRROR_PORT=8088
CS_GAME_SERVER_IP=127.0.0.1
CS_GAME_SERVER_PORT=22000

# Local browser editor for server-data\users.json. Keep remote access off unless you trust the network.
CS_USER_MANAGER=1
CS_USER_MANAGER_BASE_PATH=/user-manager
CS_USER_MANAGER_ALLOW_REMOTE=0

# Local CounterSide installation. The launcher auto-detects Steam libraries when
# possible; set this only when CounterSide is installed somewhere custom.
CS_COUNTERSIDE_MANAGED_DIR=
# Client DLL compatibility patch. The launcher applies the required local-play
# client patch set automatically before starting the listener.
# This switch is still used by npm run patch:counter-pass-client for manual
# Counter Pass UI patching.
CS_PATCH_COUNTER_PASS_CLIENT=0
# When enabled, patch:counter-pass-client restores and patches the client DLL for
# Counter Pass content unlock, event time gate, and lobby button activation.

# Optional legacy gameplay JSON roots. Leave empty for normal runtime table
# reads from installed CounterSide luac assets derived from Data\Managed.
CS_GAMEPLAY_JSON_ROOTS=
# Combat-host Lua tables. Leave empty to derive a local Lua bytecode cache from
# the encrypted assets next to CounterSide Data\Managed.
CS_GAMEPLAY_ASSET_SOURCE=auto
CS_GAMEPLAY_TABLES_DIR=
CS_CAPTURED_FLOW_DIR=.\server-data\captured-flows
CS_CAPTURED_TCP_DIR=.\server-data\captured-tcp
CS_CAPTURED_GAME_FLOW_DIR=.\server-data\captured-game-flow

# Combat host. Leave the project path enabled while developing; use the prebuilt DLL for quick smoke tests.
CS_CSHARP_COMBAT_HOST=1
CS_CSHARP_COMBAT_HOST_PROJECT=.\combat-host\CombatHost.csproj
CS_CSHARP_COMBAT_HOST_TIMEOUT_MS=20000
# CS_CSHARP_COMBAT_HOST_DLL=.\prebuilt\combat-host\CombatHost.dll
# Useful debugging toggles.
CS_VERBOSE_CAPTURE=0
CS_DEBUG_HEX=0
CS_LOG_CONFIG_EACH_CONNECTION=0
CS_REPLAY_CAPTURED_GAME_FLOW=0
CS_DYNAMIC_BATTLE_SYNC_INTERVAL_MS=33
CS_MANAGED_HOST_TICK_INTERVAL_MS=33
CS_MANAGED_HOST_PRIME_FRAMES=1
# Optional: force every local login to reuse one local user identity.
# CS_LOCAL_USER_IDENTITY_KEY=local-dev

# Fresh local accounts use official client defaults: empty roster/inventory,
# level 1, exp 0, and empty profile cosmetics. Set to all only for debug/admin
# accounts; it grants contractable table units/ships/operators, not NPC summons.
CS_NEW_ACCOUNT_ROSTER_MODE=none
# Trophies/trainers are noisy enhancement material and only apply to all mode.
CS_SEED_NEW_ACCOUNT_TROPHIES=0

# Local missions, events, shops, contracts, collection, and stamina read gameplay
# tables through the luac-backed gameplay table loader.

# Event manager. With CS_EVENT_DATE set, open tags, server time, and JOIN_LOBBY_ACK
# intervalData are derived from the packaged event tables. Contents tags are patcher-
# sensitive, so leave emission off unless you are deliberately testing content gates.
CS_EVENT_MANAGER=auto
CS_EVENT_DATE=2025-11-10
CS_EVENT_TIMEZONE=UTC
CS_EVENT_PROFILE=auto
CS_EVENT_TABLE_SCAN=known
CS_EVENT_DIAGNOSTICS=0
CS_EVENT_EMIT_CONTENTS_TAGS=0
# Official schedule rows are the normal source of historical event windows.
# date-profiles.json is now a debug override because it can deliberately force
# events onto dates where they did not officially run.
CS_EVENT_OFFICIAL_SCHEDULE=1
CS_EVENT_DATE_PROFILES=0
# Debug-only: infer generic year-only rows when no explicit/profile match exists.
# CS_EVENT_INFER_YEAR_ONLY=0
# Debug-only: broad SUMMER/SPRING/etc. inference can create false positives.
# CS_EVENT_INFER_SEASONAL_INTERVALS=0
# Counter Pass revival can advertise the lobby button from the event date.
# Use auto for rolling date-based selection, or set CS_EVENT_COUNTER_PASS_ID to force one.
CS_EVENT_COUNTER_PASS=auto
CS_EVENT_COUNTER_PASS_ID=
CS_EVENT_COUNTER_PASS_ANCHOR_DATE=2021-05-26T04:00:00Z
CS_EVENT_COUNTER_PASS_DURATION_DAYS=35
CS_EVENT_COUNTER_PASS_CADENCE_DAYS=35
CS_EVENT_EMIT_COUNTER_PASS_CONTENTS_TAGS=1
# Debug-only: legacy synthetic rolling pass selection when no schedule row matches.
# CS_EVENT_COUNTER_PASS_ROLLING=0
# Debug-only: send every referenced interval key, including inactive placeholders.
# CS_EVENT_EMIT_REQUIRED_INTERVALS=0
# Used only when a table references a date tag but no official start/end row is packaged.
# CS_EVENT_DEFAULT_WINDOW_DAYS=28

# World map revival. Dispatch rotation and timers follow CS_EVENT_DATE whenever
# the event manager is enabled, so changing that date advances branch missions.
CS_WORLDMAP_UNLOCK_ALL_BRANCHES=0
# Optional branch unlock testing overrides. Defaults mirror the client constants.
# CS_WORLDMAP_CITY_OPEN_CREDIT_COSTS=0,100000,200000,400000,800000,1600000
# CS_WORLDMAP_CITY_OPEN_CASH_COSTS=0,800,2400,4500,8000,12500
# CS_WORLDMAP_MAX_BRANCHES=6
# Keep this off for normal local play: the client already pre-validates branch opens,
# and forgiving server ACKs avoid stale local-state error popups.
CS_WORLDMAP_STRICT_BRANCH_UNLOCK=0
# Optional raid testing controls. Leave chance blank to use mission/event tables
# with a low-level fallback; force raid is useful for testing the solo raid flow.
# CS_WORLDMAP_RAID_CHANCE=
CS_WORLDMAP_FORCE_RAID=0
CS_WORLDMAP_DEFAULT_SOLO_RAID=0

# Tutorial debug.
CS_SKIP_TUTORIAL_TO_WIN=0
# Set to 1 to wipe local stage/dungeon/mission progress on login while keeping inventory and owned units.
CS_RESET_LOCAL_PROGRESS_ON_LOGIN=0
# Set to 1 when you want every login to start from tutorial phase 1, ignoring stale local completion flags.
CS_RESET_TUTORIAL_PROGRESS_ON_LOGIN=0
# Set to 1 to wipe post-tutorial main story campaign progress while keeping tutorial, inventory, and roster.
resetcampaignprogress=0
# Equivalent prefixed form for scripts or shells that prefer project-scoped names.
CS_RESET_CAMPAIGN_PROGRESS=0
# Set to 1 to wipe persisted mission/achievement completion and progress status on login.
clearAllMissionsStatus=0
CS_CLEAR_ALL_MISSIONS_STATUS=0
# Set to 1 to prune local account collections during login.
clearUnitsLevel1=0
clearGearUnenhanced=0
clearShipsLevel1=0
clearOperatorsLevel1=0
# Equivalent prefixed forms for scripts or shells that prefer project-scoped names.
CS_CLEAR_UNITS_LEVEL1=0
CS_CLEAR_GEAR_UNENHANCED=0
CS_CLEAR_SHIPS_LEVEL1=0
CS_CLEAR_OPERATORS_LEVEL1=0
# auto sends a local DB account snapshot once local items/units/progress exist.
CS_USE_LOCAL_JOIN_LOBBY_ACK=auto

# Local shop/inventory sandbox. The listener seeds missing non-core shop price resources to this starting balance.
# Set CS_LOCAL_SHOP_SEED_CORE_CURRENCIES=1 only when you deliberately want credits/quartz/admin coins/contracts prefilled too.
CS_LOCAL_SHOP_BALANCE=999999999
# CS_LOCAL_SHOP_SEED_CORE_CURRENCIES=0
# CS_REPAIR_LOCAL_SHOP_CORE_CURRENCY_SEED=1
CS_SHOP_FALLBACK_REWARD_ITEM_ID=1
CS_SHOP_FALLBACK_REWARD_COUNT=1000
CS_RESOURCE_PURCHASE_DEDUPE_MS=10000

# Attendance check-in. By default this follows the active attendance tabs for server UTC time and queues rewards in inbox mail.
# CS_DISABLE_ATTENDANCE_REWARD_MAIL=0
# loadeventfromday=2026-05-06
# CS_ACTIVE_ATTENDANCE_TAB_IDS=23148,30331,40000
# CS_ATTENDANCE_REWARD_TITLE=Attendance Check-In Reward
