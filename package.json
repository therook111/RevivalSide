{
  "name": "revivalside",
  "version": "0.3.1",
  "private": true,
  "description": "Local CounterSide revival server research tooling.",
  "scripts": {
    "listen": "node cs-listener.js",
    "check:listener": "node --check cs-listener.js && node --check server/listener.js && node --check server/packetHandlerLoader.js",
    "check:handlers": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem packet-handlers,modules -Recurse -Filter *.js | Where-Object { $_.DirectoryName -match '[\\\\/]handlers$' } | ForEach-Object { node --check $_.FullName }\"",
    "build:combat-host": "dotnet build combat-host/CombatHost.csproj --nologo",
    "build:launcher": "dotnet build tools/RevivalSideLauncherApp/RevivalSideLauncherApp.csproj --nologo",
    "publish:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-revivalside-universal-installer.ps1",
    "publish:github-release": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-revivalside-github-release.ps1",
    "download-service:dev": "npm --prefix download-service run dev",
    "download-service:start": "npm --prefix download-service start",
    "download-service:test": "npm --prefix download-service test",
    "downloadside:secrets": "cd download-service && npm run secrets:fly",
    "downloadside:deploy": "cd download-service && npm run deploy:fly",
    "ensure:gameplay-assets": "node tools/ensure-gameplay-assets.js",
    "build:gameplay-jsons": "node tools/build-prepackaged-gameplay-jsons.js",
    "patch:counter-pass-client": "dotnet run --project tools/CounterPassClientPatcher/CounterPassClientPatcher.csproj -- --env-switch",
    "patch:counter-pass-client:restore": "dotnet run --project tools/CounterPassClientPatcher/CounterPassClientPatcher.csproj -- --restore",
    "patch:counter-pass-client:legacy": "dotnet run --project tools/CounterPassClientPatcher/CounterPassClientPatcher.csproj -- --restore-first --legacy-all",
    "patch:counter-pass-client:status": "dotnet run --project tools/CounterPassClientPatcher/CounterPassClientPatcher.csproj -- --status",
    "diag:event": "node tools/event-manager-diagnostics.js",
    "import:event-schedules": "node tools/import-official-event-schedules.js",
    "generate:packet-schema": "node tools/generate-packet-schema.js",
    "coverage:join-lobby-ack": "node tools/report-join-lobby-ack-coverage.js",
    "wiki:build": "node tools/build-revivalside-wiki.js",
    "wiki:assets": "node tools/copy-wiki-assets.js",
    "wiki:serve": "node tools/serve-revivalside-wiki.js"
  }
}
